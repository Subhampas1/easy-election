# .env.example — Template Environment Variables
# Copy this file to .env and fill in your credentials.

# Google Cloud Project
GCP_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOGGING=false

# Google Cloud Storage (election resources bucket)
GCS_BUCKET_NAME=election-resources

# Google Maps Static API (optional — falls back to OpenStreetMap)
GOOGLE_MAPS_API_KEY=

# Google Vertex AI / Gemini (optional — falls back to rule-based engine)
GOOGLE_AI_API_KEY=

# Google BigQuery Analytics (optional — falls back to in-memory tracking)
BQ_DATASET_ID=election_analytics
BQ_TABLE_ID=events

# App Config
APP_ENV=development
LOG_LEVEL=INFO
