# ── Citizen Election Assistant — Environment Variables ──
# Copy this file to `.env` and fill in your values.

# Google Cloud
GCP_PROJECT_ID=promptwar-2026
GOOGLE_CLOUD_LOGGING=true
GCS_BUCKET_NAME=election-resources

# Google Maps (optional — app works without it)
GOOGLE_MAPS_API_KEY=

# App Config
APP_ENV=development
LOG_LEVEL=INFO
